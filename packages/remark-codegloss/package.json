{
  "name": "remark-codegloss",
  "version": "0.1.0",
  "description": "Remark plugin to transform annotated code fences into CodeGloss components",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "unified": ">=11"
  },
  "dependencies": {
    "unist-util-visit": "^5"
  },
  "devDependencies": {
    "@types/mdast": "^4",
    "@vitest/coverage-v8": "^4.1.4",
    "mdast-util-mdx-jsx": "^3",
    "remark-parse": "^11.0.0",
    "tsup": "^8",
    "typescript": "^6.0.2",
    "unified": "^11.0.5",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  }
}
