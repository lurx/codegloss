{
  "name": "codegloss",
  "version": "0.1.0",
  "description": "Annotated code sandbox web component",
  "type": "module",
  "sideEffects": [
    "./dist/index.js",
    "./dist/chunk-*.js"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./themes": {
      "types": "./dist/themes/index.d.ts",
      "import": "./dist/themes/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./config/node": {
      "types": "./dist/config/node.d.ts",
      "import": "./dist/config/node.js"
    },
    "./remark": {
      "types": "./dist/remark/index.d.ts",
      "import": "./dist/remark/index.js",
      "require": "./dist/remark/index.cjs"
    }
  },
  "dependencies": {
    "unist-util-visit": "^5"
  },
  "peerDependencies": {
    "unified": ">=11"
  },
  "peerDependenciesMeta": {
    "unified": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/mdast": "^4",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.4",
    "happy-dom": "^20.8.9",
    "tsup": "^8",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "mdast-util-mdx-jsx": "^3",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "scripts": {
    "generate:styles": "node scripts/inline-css.mjs",
    "prebuild": "pnpm run generate:styles",
    "build": "tsup",
    "dev": "pnpm run generate:styles && tsup --watch",
    "pretest": "pnpm run generate:styles",
    "pretest:watch": "pnpm run generate:styles",
    "pretest:coverage": "pnpm run generate:styles",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  }
}
