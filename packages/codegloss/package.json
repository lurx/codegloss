{
  "name": "codegloss",
  "version": "0.1.0",
  "description": "Annotated code sandbox web component",
  "type": "module",
  "sideEffects": [
    "./dist/index.js",
    "./dist/index.cjs",
    "./dist/react/index.js",
    "./dist/react/index.cjs",
    "./dist/vue/index.js",
    "./dist/vue/index.cjs",
    "./dist/chunk-*.js"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/svelte/code-gloss.component.svelte"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js",
      "require": "./dist/vue/index.cjs"
    },
    "./svelte": {
      "svelte": "./src/svelte/code-gloss.component.svelte",
      "default": "./src/svelte/code-gloss.component.svelte"
    },
    "./themes": {
      "types": "./dist/themes/index.d.ts",
      "import": "./dist/themes/index.js",
      "require": "./dist/themes/index.cjs"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js",
      "require": "./dist/config/index.cjs"
    },
    "./config/node": {
      "types": "./dist/config/node.d.ts",
      "import": "./dist/config/node.js",
      "require": "./dist/config/node.cjs"
    },
    "./remark": {
      "types": "./dist/remark/index.d.ts",
      "import": "./dist/remark/index.js",
      "require": "./dist/remark/index.cjs"
    }
  },
  "dependencies": {
    "unist-util-visit": "^5"
  },
  "peerDependencies": {
    "react": ">=16.14.0",
    "svelte": ">=4.0.0",
    "unified": ">=11",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "unified": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/mdast": "^4",
    "@types/node": "^22.19.17",
    "@types/react": "^18",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "^4.1.4",
    "happy-dom": "^20.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "mdast-util-mdx-jsx": "^3",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "vue": "^3.5.13"
  },
  "scripts": {
    "prebuild": "node scripts/inline-css.mjs",
    "build": "tsup",
    "dev": "node scripts/inline-css.mjs && tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  }
}
