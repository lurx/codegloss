{
	"name": "@codegloss/react",
	"version": "1.0.0",
	"description": "React wrapper for the codegloss <code-gloss> web component",
	"license": "MIT",
	"homepage": "https://lurx.github.io/codegloss/",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lurx/codegloss.git",
		"directory": "packages/react"
	},
	"bugs": "https://github.com/lurx/codegloss/issues",
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"codegloss",
		"code-annotation",
		"annotated-code",
		"syntax-highlighting",
		"react",
		"react-component"
	],
	"type": "module",
	"sideEffects": [
		"./dist/index.js"
	],
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"engines": {
		"node": ">=20"
	},
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"peerDependencies": {
		"codegloss": "workspace:*",
		"react": ">=16.14.0"
	},
	"devDependencies": {
		"@types/react": "^18",
		"@types/react-dom": "^18.3.7",
		"@vitest/coverage-v8": "^4.1.4",
		"codegloss": "workspace:*",
		"happy-dom": "^20.8.9",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"tsup": "^8",
		"typescript": "^5.9.3",
		"vitest": "^4.1.4"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	}
}
