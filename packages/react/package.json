{
  "name": "@codegloss/react",
  "version": "0.1.0",
  "description": "React wrapper for the codegloss <code-gloss> web component",
  "type": "module",
  "sideEffects": ["./dist/index.js"],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "codegloss": "workspace:*",
    "react": ">=16.14.0"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "^4.1.4",
    "codegloss": "workspace:*",
    "happy-dom": "^20.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  }
}
