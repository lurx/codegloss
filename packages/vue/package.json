{
  "name": "@codegloss/vue",
  "version": "0.1.0",
  "description": "Vue 3 wrapper for the codegloss <code-gloss> web component",
  "license": "MIT",
  "homepage": "https://lurx.github.io/codegloss/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lurx/codegloss.git",
    "directory": "packages/vue"
  },
  "bugs": "https://github.com/lurx/codegloss/issues",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": ["./dist/index.js"],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "codegloss": "workspace:*",
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "codegloss": "workspace:*",
    "happy-dom": "^20.8.9",
    "tsup": "^8",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "vue": "^3.5.13"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  }
}
